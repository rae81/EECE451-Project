<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext during project development so emulator, localhost, and LAN-hosted
         Flask instances can all be reached from debug builds and physical devices. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
